# AutoPulse Panamá — Variables de Entorno
# Copia este archivo a .env y llena los valores
# NUNCA subas .env a Git
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=autopulse
POSTGRES_PASSWORD=Auto1234
POSTGRES_DB=autopulse

# pgAdmin
PGADMIN_EMAIL=admin@autopulse.com
PGADMIN_PASSWORD=Auto1234

# Scraping — Proxies (opcional en fase inicial)
USE_PROXIES=false
PROXY_URL=

# Alertas (configurar cuando tengas clientes)
ALERT_EMAIL=cxrlosjesus@gmail.com
WHATSAPP_ALERT_NUMBER=+50766837167

# Entorno
ENVIRONMENT=development
LOG_LEVEL=INFO
